// Prisma Schema for Competitive Analysis Tool

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  passwordHash  String
  plan          String    @default("free") // free, basic, pro
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  competitors   Competitor[]
  reports       Report[]
  subscription  Subscription?
}

model Competitor {
  id              String    @id @default(uuid())
  userId          String
  name            String
  url             String
  type            String    @default("website") // website, twitter, facebook
  status          String    @default("active") // active, paused, error
  scrapeFrequency String    @default("weekly") // daily, weekly
  lastScrapedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots       Snapshot[]
  changes         Change[]

  @@index([userId])
  @@index([status])
}

model Snapshot {
  id            String   @id @default(uuid())
  competitorId  String
  url           String
  title         String?
  description   String?
  content       String?
  htmlHash      String
  metaData      Json?
  screenshotUrl String?
  httpStatus    Int
  scrapedAt     DateTime @default(now())
  createdAt     DateTime @default(now())

  competitor    Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  analyses      Analysis[]
  oldChanges    Change[] @relation("OldSnapshot")
  newChanges    Change[] @relation("NewSnapshot")

  @@index([competitorId])
  @@index([scrapedAt])
}

model Change {
  id             String   @id @default(uuid())
  competitorId   String
  oldSnapshotId  String?
  newSnapshotId  String?
  changeType     String   // new_page, content_update, deleted, title_change
  summary        String?
  diffData       Json?
  severity       String   @default("low") // low, medium, high
  detectedAt     DateTime @default(now())

  competitor     Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  oldSnapshot    Snapshot?  @relation("OldSnapshot", fields: [oldSnapshotId], references: [id])
  newSnapshot    Snapshot?  @relation("NewSnapshot", fields: [newSnapshotId], references: [id])

  @@index([competitorId])
  @@index([detectedAt])
}

model Analysis {
  id               String   @id @default(uuid())
  snapshotId       String
  keywords         Json?
  topics           Json?
  sentimentScore   Float?
  wordCount        Int?
  readabilityScore Float?
  createdAt        DateTime @default(now())

  snapshot         Snapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
}

model Report {
  id          String   @id @default(uuid())
  userId      String
  periodStart DateTime
  periodEnd   DateTime
  status      String   @default("generating") // generating, completed, failed, sent
  summary     String?
  reportData  Json?
  htmlUrl     String?
  pdfUrl      String?
  sentAt      DateTime?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([periodEnd])
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String    @unique
  stripeSubscriptionId String?   @unique
  plan                 String    // basic, pro
  status               String    // active, canceled, past_due
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
